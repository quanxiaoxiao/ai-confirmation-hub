{
  "name": "ai-confirmation-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first confirmation monitoring system for tmux-based AI workflows.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/ tests/",
    "test": "npm run build && node --test dist/tests/**/*.js",
    "test:hurl": "hurl --test --variable host=http://localhost:47321 --variable rid=$(date +%s) tests/hurl/**/*.hurl",
    "dev": "node --watch dist/src/cli/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.8",
    "zod": "^4.3.6"
  }
}
