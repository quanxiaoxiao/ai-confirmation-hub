{
  "manifest_version": 3,
  "name": "AI Confirmation Hub",
  "version": "0.1.0",
  "description": "Monitor pending AI tool confirmations from your tmux sessions",
  "permissions": ["alarms", "notifications", "storage"],
  "host_permissions": ["http://localhost:47321/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
